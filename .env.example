# Auth
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Database
DATABASE_URL="file:./dev.db"

# AI
AI_PRIMARY_PROVIDER=agentrouter
AI_FALLBACK_PROVIDER=openai
AI_TIMEOUT_MS=60000
AI_MAX_RETRIES=2
PROVIDER_STATUS_CACHE_TTL_MS=86400000
AGENT_ROUTER_TOKEN=your-agentrouter-token
AGENT_ROUTER_BASE_URL=https://agentrouter.org/v1
AGENT_ROUTER_DEFAULT_MODEL=glm-4.6
AGENT_ROUTER_MODELS=glm-4.6,deepseek-v3.2,deepseek-v3.1,deepseek-r1-0528,glm-4.5

# Backward-compatible aliases still supported by the app:
# AGENTROUTER_API_KEY=your-agentrouter-token
# AGENTROUTER_BASE_URL=https://agentrouter.org/v1
# AGENTROUTER_DEFAULT_MODEL=glm-4.6
# AGENTROUTER_MODELS=glm-4.6,deepseek-v3.2,deepseek-v3.1,deepseek-r1-0528,glm-4.5
AI_FALLBACK_MODELS=
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# Turso (if using Turso instead of SQLite)
TURSO_DATABASE_URL=your-turso-database-url
TURSO_AUTH_TOKEN=your-turso-auth-token

# Supabase
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_STORAGE_BUCKET=your-supabase-storage-bucket
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-publishable-key

# Vercel
VERCEL_ACCESS_TOKEN=your-vercel-access-token

# Pakasir billing
NEXT_PUBLIC_APP_URL=http://localhost:3000
PAKASIR_SLUG=your-pakasir-slug
PAKASIR_API_KEY=your-pakasir-api-key
# Pakasir uses the public endpoint https://app.pakasir.com for payment pages,
# transaction creation, and transaction detail verification.

# Crypto Payment
CRYPTO_PAYMENT_PRIVATE_KEY=0xacc27999f6c789ae5b402110688cb91bf5961b9391a310cf5bb614e6ce9c31c3
NEXT_PUBLIC_CRYPTO_PAYMENT_ADDRESS=0x67ca04dd05ce72ba42072116dcf13dba524c8e91

# Optional
PORT=3000
NODE_ENV=development
