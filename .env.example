# Required for production (Vercel)
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=replace_with_a_secure_random_value
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
TURSO_DATABASE_URL=libsql://<your-turso-instance>
TURSO_AUTH_TOKEN=your_turso_auth_token
DATABASE_URL=libsql://<your-turso-instance> # set equal to TURSO_DATABASE_URL

# Optional but recommended
NEXT_PUBLIC_APP_URL=https://your-domain.com
VERCEL_ACCESS_TOKEN=

# AI / other keys (only if used in production)
# OPENAI_API_KEY=
# AGENT_ROUTER_TOKEN=
