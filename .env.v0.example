# AI Providers Configuration
# Copy this file and add your API keys

# V0.app API Configuration
# Get your API key from https://v0.app/dashboard/api-keys
V0_API_KEY=your_v0_api_key_here

# Orchestrator API Configuration
# Get your API key from Orchestrator dashboard
ORCHESTRATOR_API_KEY=your_orchestrator_api_key_here

# Notes:
# - V0 will show as "V0 Web Generator (5000/req)" in model selector
# - Orchestrator will show as "Orchestrator - Deepseek V4 Flash (5000/req)" in model selector
# - Each generation costs 5,000 IDR and is deducted from user balance
# - Failed requests do not incur charges
# - Costs can be customized in lib/services/generate-billing.service.ts
